{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "node_modules/.tmp/tsc-node",
    "tsBuildInfoFile": "node_modules/.tmp/tsc-node.tsbuildinfo"
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
